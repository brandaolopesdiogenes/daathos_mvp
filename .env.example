# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Security / HTTP
# API: X-API-Key ou Authorization: Bearer <secret>. Se vazio, /daathos e /history ficam abertos (dev).
# Várias chaves: DAATHOS_API_KEYS=key1,key2 | Com id de cliente futuro: key1|tenant-a,key2|tenant-b
DAATHOS_API_KEY=
# DAATHOS_API_KEYS=
# Rate limit POST /daathos (memória): por API key se o header existir, senão por IP
# DAATHOS_RATE_LIMIT_DISABLED=true
# DAATHOS_RATE_LIMIT_WINDOW_MS=60000
# DAATHOS_RATE_LIMIT_MAX=60
# React (Vite): em frontend/.env use VITE_DAATHOS_API_KEY= mesmo segredo para o proxy enviar o header
# Comma-separated origins, or * for dev only (not recommended in production)
CORS_ORIGIN=http://localhost:5173
# Trust X-Forwarded-* when behind reverse proxy (load balancer)
TRUST_PROXY=false
# Set true in staging if you need stack traces in JSON errors (never in public prod)
EXPOSE_ERROR_DETAILS=false

# Provider API keys (never commit real values)
OPENAI_API_KEY=
CLAUDE_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=

# Multi-agent pipeline (mode=agents): um provider por agente; ordem = AGENT_PIPELINE_STEPS
# AGENT_INTERPRETER_PROVIDER=openai
# AGENT_RESEARCH_PROVIDER=perplexity
# AGENT_EXECUTOR_PROVIDER=claude
# AGENT_PIPELINE_STEPS=agent_interpreter,agent_research,agent_executor

# Automações (evento → classificar → responder → persistir). Requer providers configurados para respond.
# DAATHOS_AUTOMATIONS=true
# Evita colisão com human-in-the-loop nos mesmos tipos (ex.: new_lead):
# DAATHOS_AUTOMATION_SKIP_EVENTS=new_lead

# Sistema vivo: journal de eventos + loop SYSTEM_PULSE (monitoramento). Desligar pulso: DAATHOS_LIVE_LOOP=false
# DAATHOS_LIVE_LOOP_MS=25000
# DAATHOS_LIVE_MAX_EVENTS=150
# DAATHOS_LIVE_MAX_ACTIONS=80

# Human-in-the-loop: evento → IA propõe ação + provider → fila até aprovação na UI / POST .../approve
# DAATHOS_HUMAN_LOOP=true
# DAATHOS_HUMAN_LOOP_EVENTS=new_lead,new_data

# Connectors (POST /connect) — timeouts em ms
# CONNECTOR_PG_TIMEOUT_MS=10000
# CONNECTOR_HTTP_TIMEOUT_MS=15000
# CRM_DEFAULT_PATH=/

# Orchestration
REQUEST_TIMEOUT_MS=30000
# Ordem intermediária (OpenAI é sempre o último fallback quando configurado)
FALLBACK_ORDER=claude,deepseek,gemini,perplexity
# In-memory structured execution log (src/utils/logs.js)
EXECUTION_LOG_MAX=5000

# Conversation memory — repository pattern (src/core/memory)
# memory | postgres | supabase (supabase usa o mesmo driver pg + connection string Postgres)
CONVERSATION_STORE=memory
CONVERSATION_MEMORY_MAX=5000
# CONVERSATION_TABLE_NAME=daathos_conversations
# CONVERSATION_AUTO_MIGRATE=true
# SUPABASE_DB_URL=  # alternativa a DATABASE_URL para o mesmo repositório PG

# PostgreSQL (connectors / conversation store when CONVERSATION_STORE=postgres|supabase)
DATABASE_URL=

# External API connector
EXTERNAL_API_BASE_URL=
EXTERNAL_API_TIMEOUT_MS=30000

# CRM connector (generic HTTP layer)
CRM_API_BASE_URL=
CRM_API_KEY=
CRM_PROVIDER=generic

# --- Homologação / Railway (https://railway.com/) ---
# PORT é injetado pela plataforma. Em produção com imagem Docker, o UI é servido de frontend/dist.
# TRUST_PROXY=true
# CORS_ORIGIN=https://seu-servico.up.railway.app
# Build Docker: mapeie VITE_DAATHOS_API_KEY igual a DAATHOS_API_KEY se a UI precisar do header.
# API só estática desligada: DAATHOS_SERVE_STATIC=false
